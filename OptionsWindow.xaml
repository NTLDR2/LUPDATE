<Window x:Class="LUpdate.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LiveUpdate Options" Height="250" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Background="#D4D0C8">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="LiveUpdate Settings" FontWeight="Bold" Margin="0,0,0,10"/>
            <CheckBox Content="Automatically check for updates on startup" IsChecked="True" Margin="0,5,0,5"/>
            <CheckBox Content="Download updates in background" IsChecked="False" Margin="0,5,0,5"/>
            <TextBlock Text="(Placeholder Dialog - Settings are not yet persistent)" 
                       FontStyle="Italic" Foreground="#666" Margin="0,20,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="75" Height="23" Margin="0,0,10,0" Click="btnOk_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="75" Height="23" Click="btnOk_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
