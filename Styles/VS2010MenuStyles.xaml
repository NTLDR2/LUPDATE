<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:LUpdate">

    <!-- =============================================================================
         VS2010 Menu Styles — Ported from RDAS101
         =============================================================================
         Complete visual overhaul for Menu, MenuItem, Separator, ToolBar, and
         ToolBarTray controls. Provides VS2010/VS2012-like gradient backgrounds,
         warm golden hover highlights, and consistent border styling.
         ============================================================================= -->

    <!-- Colors -->
    <Color x:Key="VsMenuBackgroundColor">#FFCEDDED</Color>
    <Color x:Key="VsMenuBorderColor">#FF8E9BBC</Color>
    <Color x:Key="VsMenuItemSelectionFillColor">#FFFFF29D</Color>
    <Color x:Key="VsMenuItemSelectionBorderColor">#FFE5C365</Color>
    <Color x:Key="VsMenuDropdownBackgroundColor">#FFF6F6F6</Color>
    <Color x:Key="VsSeparatorColor">#FFC5C5C5</Color>
    <SolidColorBrush x:Key="VsSeparatorBrush" Color="{StaticResource VsSeparatorColor}"/>
    
    <SolidColorBrush x:Key="VsMenuBackgroundBrush" Color="{StaticResource VsMenuBackgroundColor}"/>
    <SolidColorBrush x:Key="VsMenuBorderBrush" Color="{StaticResource VsMenuBorderColor}"/>
    
    <!-- Warm golden highlight gradient for hovered/selected menu items -->
    <LinearGradientBrush x:Key="VsMenuItemSelectionFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFFE0" Offset="0"/>
        <GradientStop Color="#FFFFF29D" Offset="0.5"/>
        <GradientStop Color="#FFFFE080" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Golden border for hovered/selected menu items -->
    <LinearGradientBrush x:Key="VsMenuItemSelectionBorderBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFE5C365" Offset="0"/>
        <GradientStop Color="#FFD4A017" Offset="1"/>
    </LinearGradientBrush>

    <!-- Light gray background for dropdown popup panels -->
    <SolidColorBrush x:Key="VsMenuDropdownBackgroundBrush" Color="{StaticResource VsMenuDropdownBackgroundColor}"/>

    <!-- ═══════════════════════════════════════════════════════════════
         Menu Style (Top Level Bar)
         Blue gradient background with accent border at the bottom.
         ═══════════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type Menu}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFB4CADB" Offset="0"/>
                    <GradientStop Color="#FFCEDDED" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="BorderBrush" Value="{StaticResource VsMenuBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FontFamily" Value="{DynamicResource MenuBarFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource MenuBarFontSize}"/>
        <Setter Property="Padding" Value="0,1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Menu}">
                    <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         MenuItem Style
         Complete ControlTemplate with:
           - Icon, Header, InputGestureText, and Submenu Arrow columns
           - Role-based triggers (TopLevelHeader, TopLevelItem, SubmenuHeader, SubmenuItem)
           - Warm golden hover highlight (IsHighlighted)
           - Disabled state dimming
           - Custom left-aligned popup via PopupHelper
         ═══════════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontFamily" Value="{DynamicResource MenuBarFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource MenuBarFontSize}"/>
        <Setter Property="Padding" Value="0,2"/>
        <Setter Property="FlowDirection" Value="LeftToRight"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="Border" BorderThickness="1" Background="Transparent" SnapsToDevicePixels="True" Padding="{TemplateBinding Padding}">
                        <Grid>
                            <!-- Content for TopLevel/SubMenu Item -->
                            <Grid x:Name="ContentGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="Icon" Margin="0" VerticalAlignment="Center" ContentSource="Icon"/>
                                <ContentPresenter x:Name="HeaderHost" Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" Margin="5,2,5,2"/>
                                <TextBlock x:Name="InputGestureText" Grid.Column="2" Text="{TemplateBinding InputGestureText}" Margin="5,2,0,2" DockPanel.Dock="Right" Foreground="#FF555555"/>
                                <!-- Arrow for Submenu -->
                                <Path x:Name="Arrow" Grid.Column="3" Data="M 0,0 L 4,3.5 L 0,7 Z" Fill="Black" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" Margin="4,0,4,0"/>
                            </Grid>
                            
                            <!-- Popup for Submenu -->
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   local:PopupHelper.ForceLeftAlign="True"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                                   Placement="Custom" 
                                   PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                                <Border x:Name="SubMenuBorder" Background="{StaticResource VsMenuDropdownBackgroundBrush}" BorderBrush="#FF8E9BBC" BorderThickness="1" Padding="2">
                                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Hidden">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" Grid.IsSharedSizeScope="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    
                    <ControlTemplate.Triggers>
                        <!-- Role: TopLevelHeader (e.g. File, Edit) -->
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="PART_Popup" Property="VerticalOffset" Value="4"/>
                            <Setter Property="Padding" Value="2,2,2,2"/>
                            <Setter TargetName="HeaderHost" Property="Margin" Value="8,2,4,2"/>
                            <Setter TargetName="HeaderHost" Property="HorizontalAlignment" Value="Center"/>
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        
                        <!-- Role: TopLevelItem (e.g. button on bar) -->
                        <Trigger Property="Role" Value="TopLevelItem">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Padding" Value="2,2,2,2"/>
                            <Setter TargetName="HeaderHost" Property="Margin" Value="8,2,4,2"/>
                            <Setter TargetName="HeaderHost" Property="HorizontalAlignment" Value="Center"/>
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        
                        <!-- Role: SubmenuHeader (e.g. Open Recent ->) -->
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
                            <Setter TargetName="Icon" Property="Margin" Value="6,0,6,0"/>
                        </Trigger>
                        
                        <Trigger Property="Role" Value="SubmenuItem">
                            <Setter TargetName="Icon" Property="Margin" Value="6,0,6,0"/>
                        </Trigger>
                        
                        <!-- IsHighlighted (Hover) — warm golden highlight -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource VsMenuItemSelectionFillBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource VsMenuItemSelectionBorderBrush}"/>
                        </Trigger>

                        <!-- IsEnabled — dimmed when disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#FF888888"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         Separator Style — thin gray line with margins
         ═══════════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type Separator}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border BorderBrush="{StaticResource VsSeparatorBrush}" BorderThickness="0,1,0,0" Margin="4,2,4,2"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ═══════════════════════════════════════════════════════════════
         ToolBar Style — gradient background with VS2010-style buttons
         ═══════════════════════════════════════════════════════════════ -->
     <Style TargetType="{x:Type ToolBar}">
        <Setter Property="FontFamily" Value="{DynamicResource ApplicationFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource ApplicationFontSize}"/>
        <Setter Property="Padding" Value="0,1,0,-1"/>
        <Setter Property="Background">
            <Setter.Value>
               <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFB4CADB" Offset="0"/>
                    <GradientStop Color="#FFCEDDED" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <Style x:Key="{x:Static ToolBar.ButtonStyleKey}" TargetType="{x:Type Button}">
                <Setter Property="Padding" Value="4"/>
                <Setter Property="Margin" Value="1"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" TargetName="Border" Value="{StaticResource VsMenuItemSelectionFillBrush}"/>
                                    <Setter Property="BorderBrush" TargetName="Border" Value="{StaticResource VsMenuItemSelectionBorderBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" TargetName="Border" Value="{StaticResource VsMenuItemSelectionBorderBrush}"/>
                                    <Setter Property="BorderBrush" TargetName="Border" Value="{StaticResource VsMenuBorderBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
             <Style x:Key="{x:Static ToolBar.ToggleButtonStyleKey}" TargetType="{x:Type ToggleButton}">
                <Setter Property="Padding" Value="4"/>
                <Setter Property="Margin" Value="1"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                 <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" TargetName="Border" Value="{StaticResource VsMenuItemSelectionFillBrush}"/>
                                    <Setter Property="BorderBrush" TargetName="Border" Value="{StaticResource VsMenuItemSelectionBorderBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" TargetName="Border" Value="{StaticResource VsMenuItemSelectionFillBrush}"/>
                                    <Setter Property="BorderBrush" TargetName="Border" Value="{StaticResource VsMenuItemSelectionBorderBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>
    </Style>

    <Style TargetType="{x:Type ToolBarTray}">
        <Setter Property="Background">
            <Setter.Value>
               <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFB4CADB" Offset="0"/>
                    <GradientStop Color="#FFCEDDED" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
