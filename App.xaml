<Application x:Class="LUpdate.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- VS2010 Menu/Toolbar styles ported from RDAS101 -->
                <ResourceDictionary Source="Styles/VS2010MenuStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Font resources (used by VS2010MenuStyles.xaml via DynamicResource) -->
            <FontFamily x:Key="ApplicationFontFamily">Tahoma</FontFamily>
            <sys:Double x:Key="ApplicationFontSize">12</sys:Double>
            <FontFamily x:Key="MenuBarFontFamily">Tahoma</FontFamily>
            <sys:Double x:Key="MenuBarFontSize">12</sys:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
